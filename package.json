{
  "name": "domain-renewal-reminder",
  "version": "1.0.0",
  "description": "Domain renewal reminder service built on Cloudflare Workers",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "cd frontend && npm install && npm run build",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "lint:all": "npm run lint && cd frontend && npm run lint",
    "prepare": "husky"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "domain",
    "reminder",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "fast-check": "^4.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0",
    "wrangler": "^4.75.0"
  },
  "dependencies": {
    "hono": "^4.12.23"
  }
}
